{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=ClinicManagementDB;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "JwtSettings": {
    "SecretKey": "ClinicManagementSuperSecretKeyThatIsAtLeast32Characters!",
    "Issuer": "ClinicManagementAPI",
    "Audience": "ClinicManagementClient",
    "AccessTokenExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 7
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000", "http://localhost:5173" ]
  }
}