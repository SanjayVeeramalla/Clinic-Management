-- ============================================================
-- APPOINTMENT PROCEDURES
-- ============================================================

-- *** CORE REAL-WORLD EDGE CASES ***
-- [B1]  Cannot book past dates
-- [B2]  Same-day booking: time slot must be >= 30 min from NOW (not already passed)
-- [B3]  Cannot book more than 90 days in advance
-- [B4]  Doctor must be IsAvailable=1 and user IsActive=1
-- [B5]  Patient user account must be active
-- [B6]  Doctor slot conflict (another patient already booked that slot)
-- [B7]  Patient overlap (patient already has appointment at same date+time)
-- [B8]  Patient cannot book MORE THAN 1 appointment per day with the SAME doctor
-- [B9]  Doctor must have an active schedule on that day of week
-- [B10] Appointment time must fall within the schedule's StartTime–EndTime window
-- [B11] Appointment time must align to a valid slot boundary (e.g. every 30 min from 09:00)
CREATE OR ALTER PROCEDURE sp_BookAppointment
    @PatientId       INT,
    @DoctorId        INT,
    @AppointmentDate DATE,
    @AppointmentTime TIME,
    @ReasonForVisit  NVARCHAR(500),
    @AppointmentId   INT OUTPUT,
    @Message         NVARCHAR(200) OUTPUT
AS
BEGIN
    SET NOCOUNT ON;
    BEGIN TRY
        BEGIN TRANSACTION;

        -- [B1] Past date
        IF @AppointmentDate < CAST(GETUTCDATE() AS DATE)
        BEGIN
            SET @AppointmentId = -1;  SET @Message = 'Cannot book appointments for past dates';
            ROLLBACK; RETURN;
        END

        -- [B2] Same-day: slot must be at least 30 minutes from now
        IF @AppointmentDate = CAST(GETUTCDATE() AS DATE)
        BEGIN
            DECLARE @NowTime TIME = CAST(GETUTCDATE() AS TIME);
            IF @AppointmentTime <= DATEADD(MINUTE, 30, @NowTime)
            BEGIN
                SET @AppointmentId = -1;
                SET @Message = 'This slot has already passed. Please select a future slot.';
                ROLLBACK; RETURN;
            END
        END

        -- [B3] Max 90-day advance booking
        IF @AppointmentDate > DATEADD(DAY, 90, CAST(GETUTCDATE() AS DATE))
        BEGIN
            SET @AppointmentId = -1;
            SET @Message = 'Appointments cannot be booked more than 90 days in advance';
            ROLLBACK; RETURN;
        END

        -- [B4] Doctor must be active and available
        IF NOT EXISTS (
            SELECT 1 FROM Doctors d INNER JOIN Users u ON d.UserId = u.UserId
            WHERE d.DoctorId = @DoctorId AND d.IsAvailable = 1 AND u.IsActive = 1
        )
        BEGIN
            SET @AppointmentId = -1;
            SET @Message = 'Doctor is not currently accepting appointments';
            ROLLBACK; RETURN;
        END

        -- [B5] Patient must exist and be active
        IF NOT EXISTS (
            SELECT 1 FROM Patients p INNER JOIN Users u ON p.UserId = u.UserId
            WHERE p.PatientId = @PatientId AND u.IsActive = 1
        )
        BEGIN
            SET @AppointmentId = -1;
            SET @Message = 'Patient account not found or inactive';
            ROLLBACK; RETURN;
        END

        -- [B6] Doctor slot conflict
        IF EXISTS (
            SELECT 1 FROM Appointments a
            INNER JOIN AppointmentStatuses ast ON a.StatusId = ast.StatusId
            WHERE a.DoctorId = @DoctorId AND a.AppointmentDate = @AppointmentDate
              AND a.AppointmentTime = @AppointmentTime
              AND ast.StatusName NOT IN ('Cancelled','NoShow')
        )
        BEGIN
            SET @AppointmentId = -1;
            SET @Message = 'This time slot is already booked. Please choose another.';
            ROLLBACK; RETURN;
        END

        -- [B7] Patient overlap — patient already has any appointment at this exact date+time
        IF EXISTS (
            SELECT 1 FROM Appointments a
            INNER JOIN AppointmentStatuses ast ON a.StatusId = ast.StatusId
            WHERE a.PatientId = @PatientId AND a.AppointmentDate = @AppointmentDate
              AND a.AppointmentTime = @AppointmentTime
              AND ast.StatusName NOT IN ('Cancelled','NoShow')
        )
        BEGIN
            SET @AppointmentId = -1;
            SET @Message = 'You already have an appointment at this date and time';
            ROLLBACK; RETURN;
        END

        -- [B8] Patient cannot have more than 1 active appointment per day with same doctor
        IF EXISTS (
            SELECT 1 FROM Appointments a
            INNER JOIN AppointmentStatuses ast ON a.StatusId = ast.StatusId
            WHERE a.PatientId = @PatientId AND a.DoctorId = @DoctorId
              AND a.AppointmentDate = @AppointmentDate
              AND ast.StatusName NOT IN ('Cancelled','NoShow')
        )
        BEGIN
            SET @AppointmentId = -1;
            SET @Message = 'You already have an appointment with this doctor on this date';
            ROLLBACK; RETURN;
        END

        -- [B9] Doctor must have active schedule on this day of week
        DECLARE @DayOfWeek INT = DATEPART(WEEKDAY, @AppointmentDate) - 1;
        DECLARE @SchedStart TIME, @SchedEnd TIME, @SlotDuration INT;

        SELECT @SchedStart   = ds.StartTime,
               @SchedEnd     = ds.EndTime,
               @SlotDuration = ds.SlotDurationMinutes
        FROM DoctorSchedules ds
        WHERE ds.DoctorId = @DoctorId AND ds.DayOfWeek = @DayOfWeek AND ds.IsActive = 1;

        IF @SchedStart IS NULL
        BEGIN
            SET @AppointmentId = -1;
            SET @Message = 'Doctor does not work on this day of the week';
            ROLLBACK; RETURN;
        END

        -- [B10] Time must fall within the working window
        IF @AppointmentTime < @SchedStart OR @AppointmentTime >= @SchedEnd
        BEGIN
            SET @AppointmentId = -1;
            SET @Message = 'Selected time is outside the doctor''s working hours for this day';
            ROLLBACK; RETURN;
        END

        -- [B11] Time must align to a valid slot boundary
        DECLARE @MinutesFromStart INT = DATEDIFF(MINUTE, @SchedStart, @AppointmentTime);
        IF @MinutesFromStart % @SlotDuration != 0
        BEGIN
            SET @AppointmentId = -1;
            SET @Message = 'Invalid slot. Please select from the available time slots.';
            ROLLBACK; RETURN;
        END

        -- All checks passed — book the appointment
        DECLARE @PendingStatusId INT;
        SELECT @PendingStatusId = StatusId FROM AppointmentStatuses WHERE StatusName = 'Pending';

        INSERT INTO Appointments (PatientId, DoctorId, AppointmentDate, AppointmentTime, StatusId, ReasonForVisit)
        VALUES (@PatientId, @DoctorId, @AppointmentDate, @AppointmentTime, @PendingStatusId, @ReasonForVisit);

        SET @AppointmentId = SCOPE_IDENTITY();
        SET @Message       = 'Appointment booked successfully';
        COMMIT;
    END TRY
    BEGIN CATCH
        IF @@TRANCOUNT > 0 ROLLBACK;
        SET @AppointmentId = -1;  SET @Message = ERROR_MESSAGE();
    END CATCH
END
GO

