        IF @DateOfBirth IS NOT NULL AND @DateOfBirth >= CAST(GETUTCDATE() AS DATE)
        BEGIN
            SET @Message = 'Date of birth must be in the past';
            ROLLBACK; RETURN;
        END

        UPDATE Users    SET FullName = @FullName, Phone = @Phone, UpdatedAt = GETUTCDATE() WHERE UserId = @UserId;
        UPDATE Patients SET DateOfBirth = @DateOfBirth, Gender = @Gender, BloodGroup = @BloodGroup,
                           Address = @Address, EmergencyContact = @EmergencyContact, MedicalHistory = @MedicalHistory
        WHERE PatientId = @PatientId;

        SET @Message = 'Profile updated successfully';
        COMMIT;
    END TRY
    BEGIN CATCH
        IF @@TRANCOUNT > 0 ROLLBACK;
        SET @Message = ERROR_MESSAGE();
