CREATE OR ALTER PROCEDURE sp_GetAppointmentById
    @AppointmentId INT
AS
BEGIN
    SET NOCOUNT ON;
    SELECT a.AppointmentId, a.AppointmentDate, a.AppointmentTime,
           p.PatientId,  pu.FullName AS PatientName,  pu.Phone AS PatientPhone,
           d.DoctorId,   du.FullName AS DoctorName,   s.Name   AS Specialization,
           ast.StatusName AS Status, ast.StatusId,
           a.ReasonForVisit, a.Notes, a.CancellationReason,
           pr.PrescriptionId, pr.Diagnosis, pr.Medications, pr.Instructions, pr.FollowUpDate
    FROM Appointments a
    INNER JOIN Patients p              ON a.PatientId         = p.PatientId
    INNER JOIN Users pu                ON p.UserId            = pu.UserId
    INNER JOIN Doctors d               ON a.DoctorId          = d.DoctorId
    INNER JOIN Users du                ON d.UserId            = du.UserId
    INNER JOIN Specializations s       ON d.SpecializationId  = s.SpecializationId
    INNER JOIN AppointmentStatuses ast ON a.StatusId          = ast.StatusId
    LEFT  JOIN Prescriptions pr         ON a.AppointmentId    = pr.AppointmentId
    WHERE a.AppointmentId = @AppointmentId;
END
