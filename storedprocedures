CREATE OR ALTER PROCEDURE sp_UpdatePatientProfile
    @PatientId        INT,
    @FullName         NVARCHAR(150),
    @Phone            NVARCHAR(15),
    @DateOfBirth      DATE,
    @Gender           NVARCHAR(10),
    @BloodGroup       NVARCHAR(5),
    @Address          NVARCHAR(300),
    @EmergencyContact NVARCHAR(15),
    @MedicalHistory   NVARCHAR(MAX),
    @Message          NVARCHAR(200) OUTPUT
AS
BEGIN
    SET NOCOUNT ON;
    BEGIN TRY
        BEGIN TRANSACTION;

        DECLARE @UserId INT;
        SELECT @UserId = UserId FROM Patients WHERE PatientId = @PatientId;
        IF @UserId IS NULL
        BEGIN
            SET @Message = 'Patient not found';
            ROLLBACK; RETURN;
        END

        IF @DateOfBirth IS NOT NULL AND @DateOfBirth >= CAST(GETUTCDATE() AS DATE)
        BEGIN
            SET @Message = 'Date of birth must be in the past';
            ROLLBACK; RETURN;
        END

        UPDATE Users    SET FullName = @FullName, Phone = @Phone, UpdatedAt = GETUTCDATE() WHERE UserId = @UserId;
        UPDATE Patients SET DateOfBirth = @DateOfBirth, Gender = @Gender, BloodGroup = @BloodGroup,
                           Address = @Address, EmergencyContact = @EmergencyContact, MedicalHistory = @MedicalHistory
        WHERE PatientId = @PatientId;

        SET @Message = 'Profile updated successfully';
        COMMIT;
    END TRY
    BEGIN CATCH
        IF @@TRANCOUNT > 0 ROLLBACK;
        SET @Message = ERROR_MESSAGE();
    END CATCH
END
GO

