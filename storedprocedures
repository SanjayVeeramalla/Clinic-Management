-- Edge cases covered:
--   [C1] Appointment not found
--   [C2] Already completed → cannot cancel
--   [C3] Already cancelled → reject (idempotency)
--   [C4] NoShow → cannot cancel
--   [C5] Patient cancellation requires >= 24 hours notice
--   [C6] Patient can only cancel their OWN appointment
--   [C7] Doctors and Admins can cancel any time (emergency override)
CREATE OR ALTER PROCEDURE sp_CancelAppointment
    @AppointmentId      INT,
    @CancelledByUserId  INT,
    @CancellationReason NVARCHAR(500),
    @Message            NVARCHAR(200) OUTPUT
AS
BEGIN
    SET NOCOUNT ON;
    BEGIN TRY
        BEGIN TRANSACTION;

        DECLARE @CurrentStatusId INT, @AppointmentDate DATE, @AppointmentTime TIME,
                @PatientUserId INT, @DoctorUserId INT, @CancellerRole NVARCHAR(50);

        SELECT @CurrentStatusId = a.StatusId,
               @AppointmentDate = a.AppointmentDate,
               @AppointmentTime = a.AppointmentTime,
               @PatientUserId   = pu.UserId,
               @DoctorUserId    = du.UserId
        FROM Appointments a
        INNER JOIN Patients p ON a.PatientId = p.PatientId
        INNER JOIN Users pu   ON p.UserId    = pu.UserId
        INNER JOIN Doctors d  ON a.DoctorId  = d.DoctorId
        INNER JOIN Users du   ON d.UserId    = du.UserId
        WHERE a.AppointmentId = @AppointmentId;

        -- [C1] Appointment must exist
        IF @CurrentStatusId IS NULL
        BEGIN
            SET @Message = 'Appointment not found';
            ROLLBACK; RETURN;
        END

        SELECT @CancellerRole = r.RoleName FROM Users u INNER JOIN Roles r ON u.RoleId = r.RoleId WHERE u.UserId = @CancelledByUserId;

        DECLARE @CompletedId INT, @CancelledId INT, @NoShowId INT;
        SELECT @CompletedId = StatusId FROM AppointmentStatuses WHERE StatusName = 'Completed';
        SELECT @CancelledId = StatusId FROM AppointmentStatuses WHERE StatusName = 'Cancelled';
        SELECT @NoShowId    = StatusId FROM AppointmentStatuses WHERE StatusName = 'NoShow';

        -- [C2] Cannot cancel completed
        IF @CurrentStatusId = @CompletedId
        BEGIN
            SET @Message = 'Cannot cancel a completed appointment';
            ROLLBACK; RETURN;
        END

        -- [C3] Already cancelled
        IF @CurrentStatusId = @CancelledId
        BEGIN
            SET @Message = 'This appointment is already cancelled';
            ROLLBACK; RETURN;
        END

        -- [C4] Cannot cancel a no-show
        IF @CurrentStatusId = @NoShowId
        BEGIN
            SET @Message = 'Cannot cancel a no-show appointment';
            ROLLBACK; RETURN;
        END

        -- [C5] & [C6] Patient-specific rules
        IF @CancellerRole = 'Patient'
        BEGIN
            -- Ownership: patient can only cancel their own
            IF @PatientUserId != @CancelledByUserId
            BEGIN
                SET @Message = 'You can only cancel your own appointments';
                ROLLBACK; RETURN;
            END

            -- 24-hour notice required
            DECLARE @AppointmentDatetime DATETIME2 =
                CAST(@AppointmentDate AS DATETIME2) + CAST(@AppointmentTime AS DATETIME2);
            IF @AppointmentDatetime <= DATEADD(HOUR, 24, GETUTCDATE())
            BEGIN
                SET @Message = 'Appointments must be cancelled at least 24 hours in advance';
                ROLLBACK; RETURN;
            END
        END
        -- [C7] Doctors and Admins can cancel any appointment at any time

        UPDATE Appointments
        SET StatusId           = @CancelledId,
            CancellationReason = @CancellationReason,
            UpdatedAt          = GETUTCDATE()
        WHERE AppointmentId = @AppointmentId;

        SET @Message = 'Appointment cancelled successfully';
        COMMIT;
    END TRY
    BEGIN CATCH
        IF @@TRANCOUNT > 0 ROLLBACK;
        SET @Message = ERROR_MESSAGE();
    END CATCH
END
GO

-- Edge cases covered:
--   [T1] Appointment not found
--   [T2] Invalid status name
--   [T3] Completed → terminal, no changes allowed
--   [T4] Cancelled → terminal, no changes allowed
--   [T5] NoShow    → terminal, no changes allowed
--   [T6] Valid transitions only:
--          Pending   → Confirmed | Cancelled | NoShow
--          Confirmed → Completed | Cancelled | NoShow
--   [T7] Doctor ownership: doctor can only update their OWN appointments
CREATE OR ALTER PROCEDURE sp_UpdateAppointmentStatus
    @AppointmentId     INT,
    @NewStatusName     NVARCHAR(50),
    @Notes             NVARCHAR(MAX) = NULL,
    @UpdatedByDoctorId INT           = NULL,   -- NULL = admin (skips ownership check)
    @Message           NVARCHAR(200) OUTPUT
AS
BEGIN
    SET NOCOUNT ON;
    BEGIN TRY
        BEGIN TRANSACTION;

        DECLARE @CurrentStatusName NVARCHAR(50), @NewStatusId INT, @AppointmentDoctorId INT;

        SELECT @CurrentStatusName    = ast.StatusName,
               @AppointmentDoctorId = a.DoctorId
        FROM Appointments a
        INNER JOIN AppointmentStatuses ast ON a.StatusId = ast.StatusId
        WHERE a.AppointmentId = @AppointmentId;

        -- [T1] Appointment must exist
        IF @CurrentStatusName IS NULL
        BEGIN
            SET @Message = 'Appointment not found';
            ROLLBACK; RETURN;
        END

        -- [T7] Ownership check for doctors
        IF @UpdatedByDoctorId IS NOT NULL AND @AppointmentDoctorId != @UpdatedByDoctorId
        BEGIN
            SET @Message = 'You can only update status for your own appointments';
            ROLLBACK; RETURN;
        END

        -- [T2] Validate new status name
        SELECT @NewStatusId = StatusId FROM AppointmentStatuses WHERE StatusName = @NewStatusName;
        IF @NewStatusId IS NULL
        BEGIN
            SET @Message = 'Invalid status: ' + ISNULL(@NewStatusName,'null');
            ROLLBACK; RETURN;
        END

        -- [T3] Completed is terminal
        IF @CurrentStatusName = 'Completed'
        BEGIN
            SET @Message = 'A completed appointment cannot be changed';
            ROLLBACK; RETURN;
        END

        -- [T4] Cancelled is terminal
        IF @CurrentStatusName = 'Cancelled'
        BEGIN
            SET @Message = 'A cancelled appointment cannot be changed';
            ROLLBACK; RETURN;
        END

        -- [T5] NoShow is terminal
        IF @CurrentStatusName = 'NoShow'
        BEGIN
            SET @Message = 'A no-show appointment cannot be changed';
            ROLLBACK; RETURN;
        END

        -- [T6] Enforce valid transition graph
        IF @CurrentStatusName = 'Pending' AND @NewStatusName NOT IN ('Confirmed','Cancelled','NoShow')
        BEGIN
            SET @Message = 'Pending → only Confirmed, Cancelled, or NoShow allowed';
            ROLLBACK; RETURN;
        END

        IF @CurrentStatusName = 'Confirmed' AND @NewStatusName NOT IN ('Completed','Cancelled','NoShow')
        BEGIN
            SET @Message = 'Confirmed → only Completed, Cancelled, or NoShow allowed';
            ROLLBACK; RETURN;
        END

        UPDATE Appointments
        SET StatusId  = @NewStatusId,
            Notes     = ISNULL(@Notes, Notes),
            UpdatedAt = GETUTCDATE()
        WHERE AppointmentId = @AppointmentId;

        SET @Message = 'Status updated to ' + @NewStatusName;
        COMMIT;
    END TRY
    BEGIN CATCH
        IF @@TRANCOUNT > 0 ROLLBACK;
        SET @Message = ERROR_MESSAGE();
    END CATCH
END
GO

