-- Edge cases covered:
--   [D1] User must exist and be active
--   [D2] User must have 'Doctor' role (cannot create doctor profile for a Patient)
--   [D3] Doctor profile already exists for this user (no duplicates)
--   [D4] License number must be unique globally
--   [D5] Specialization must exist
--   [D6] Consultation fee cannot be negative
CREATE OR ALTER PROCEDURE sp_CreateDoctor
    @UserId            INT,
    @SpecializationId  INT,
    @LicenseNumber     NVARCHAR(100),
    @YearsOfExperience INT,
    @ConsultationFee   DECIMAL(10,2),
    @DoctorId          INT OUTPUT,
    @Message           NVARCHAR(200) OUTPUT
AS
BEGIN
    SET NOCOUNT ON;
    BEGIN TRY
        BEGIN TRANSACTION;

        -- [D1] User must exist and be active
        IF NOT EXISTS (SELECT 1 FROM Users WHERE UserId = @UserId AND IsActive = 1)
        BEGIN
            SET @DoctorId = -1;  SET @Message = 'User not found or account is inactive';
            ROLLBACK; RETURN;
        END

        -- [D2] User must have Doctor role
        DECLARE @UserRole NVARCHAR(50);
        SELECT @UserRole = r.RoleName FROM Users u INNER JOIN Roles r ON u.RoleId = r.RoleId WHERE u.UserId = @UserId;
        IF @UserRole != 'Doctor'
        BEGIN
            SET @DoctorId = -1;  SET @Message = 'User must have the Doctor role to create a doctor profile';
            ROLLBACK; RETURN;
        END

        -- [D3] No duplicate doctor profile
        IF EXISTS (SELECT 1 FROM Doctors WHERE UserId = @UserId)
        BEGIN
            SET @DoctorId = -1;  SET @Message = 'A doctor profile already exists for this user';
            ROLLBACK; RETURN;
        END

        -- [D4] License number globally unique
        IF EXISTS (SELECT 1 FROM Doctors WHERE LicenseNumber = @LicenseNumber)
        BEGIN
            SET @DoctorId = -1;  SET @Message = 'This license number is already registered';
            ROLLBACK; RETURN;
        END

        -- [D5] Specialization must exist
        IF NOT EXISTS (SELECT 1 FROM Specializations WHERE SpecializationId = @SpecializationId)
        BEGIN
            SET @DoctorId = -1;  SET @Message = 'Specialization not found';
            ROLLBACK; RETURN;
        END

        -- [D6] Fee cannot be negative
        IF @ConsultationFee < 0
        BEGIN
            SET @DoctorId = -1;  SET @Message = 'Consultation fee cannot be negative';
            ROLLBACK; RETURN;
        END

        INSERT INTO Doctors (UserId, SpecializationId, LicenseNumber, YearsOfExperience, ConsultationFee)
        VALUES (@UserId, @SpecializationId, @LicenseNumber, @YearsOfExperience, @ConsultationFee);

        SET @DoctorId = SCOPE_IDENTITY();
        SET @Message  = 'Doctor profile created successfully';
        COMMIT;
    END TRY
    BEGIN CATCH
        IF @@TRANCOUNT > 0 ROLLBACK;
        SET @DoctorId = -1;  SET @Message = ERROR_MESSAGE();
    END CATCH
END
GO

