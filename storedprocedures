CREATE OR ALTER PROCEDURE sp_GetDashboardStats
AS
BEGIN
    SET NOCOUNT ON;
    SELECT
        (SELECT COUNT(*) FROM Users u INNER JOIN Roles r ON u.RoleId=r.RoleId WHERE r.RoleName='Patient' AND u.IsActive=1) AS TotalPatients,
        (SELECT COUNT(*) FROM Users u INNER JOIN Roles r ON u.RoleId=r.RoleId WHERE r.RoleName='Doctor'  AND u.IsActive=1) AS TotalDoctors,
        (SELECT COUNT(*) FROM Appointments) AS TotalAppointments,
        (SELECT COUNT(*) FROM Appointments a INNER JOIN AppointmentStatuses ast ON a.StatusId=ast.StatusId WHERE ast.StatusName='Pending')   AS PendingAppointments,
        (SELECT COUNT(*) FROM Appointments a INNER JOIN AppointmentStatuses ast ON a.StatusId=ast.StatusId WHERE ast.StatusName='Completed') AS CompletedAppointments,
        (SELECT COUNT(*) FROM Appointments WHERE CAST(AppointmentDate AS DATE)=CAST(GETUTCDATE() AS DATE)) AS TodayAppointments;
END
GO

CREATE OR ALTER PROCEDURE sp_GetAppointmentSummaryReport
    @FromDate DATE,
    @ToDate   DATE
AS
BEGIN
    SET NOCOUNT ON;
    IF @FromDate > @ToDate BEGIN RAISERROR('FromDate cannot be after ToDate',16,1); RETURN; END

    SELECT ast.StatusName AS Status,
           COUNT(*) AS Count,
           COUNT(*) * 100.0 / NULLIF(SUM(COUNT(*)) OVER (), 0) AS Percentage
    FROM Appointments a
    INNER JOIN AppointmentStatuses ast ON a.StatusId = ast.StatusId
    WHERE a.AppointmentDate BETWEEN @FromDate AND @ToDate
    GROUP BY ast.StatusName
    ORDER BY Count DESC;
END
GO

CREATE OR ALTER PROCEDURE sp_GetDoctorWorkloadReport
    @FromDate DATE,
    @ToDate   DATE
AS
BEGIN
    SET NOCOUNT ON;
    IF @FromDate > @ToDate BEGIN RAISERROR('FromDate cannot be after ToDate',16,1); RETURN; END

    SELECT d.DoctorId, u.FullName AS DoctorName, s.Name AS Specialization,
           COUNT(a.AppointmentId) AS TotalAppointments,
           SUM(CASE WHEN ast.StatusName='Completed' THEN 1 ELSE 0 END) AS Completed,
           SUM(CASE WHEN ast.StatusName='Cancelled' THEN 1 ELSE 0 END) AS Cancelled,
           SUM(CASE WHEN ast.StatusName='Pending'   THEN 1 ELSE 0 END) AS Pending,
           SUM(CASE WHEN ast.StatusName='NoShow'    THEN 1 ELSE 0 END) AS NoShow
    FROM Doctors d
    INNER JOIN Users u           ON d.UserId           = u.UserId
    INNER JOIN Specializations s ON d.SpecializationId = s.SpecializationId
    LEFT  JOIN Appointments a    ON d.DoctorId = a.DoctorId AND a.AppointmentDate BETWEEN @FromDate AND @ToDate
    LEFT  JOIN AppointmentStatuses ast ON a.StatusId = ast.StatusId
    WHERE u.IsActive = 1
    GROUP BY d.DoctorId, u.FullName, s.Name
    ORDER BY TotalAppointments DESC;
END
GO

-- *** KEY REAL-WORLD EDGE CASE ***
-- Edge cases covered:
--   [DA1] User not found
--   [DA2] Admin cannot be deactivated
--   [DA3] Already inactive (idempotency — no error, just inform)
--   [DA4] Immediately revoke ALL active refresh tokens → cached tokens stop working instantly
--   [DA5] Doctor deactivated: mark IsAvailable=0, cancel ALL future Pending+Confirmed appointments
--   [DA6] Patient deactivated: cancel their future Pending+Confirmed appointments
--   Both [DA5] and [DA6] set a descriptive CancellationReason for each affected appointment
CREATE OR ALTER PROCEDURE sp_DeactivateUser
    @UserId               INT,
    @DeactivatedByAdminId INT,
    @Message              NVARCHAR(200) OUTPUT
AS
BEGIN
    SET NOCOUNT ON;
    BEGIN TRY
        BEGIN TRANSACTION;

        -- [DA1] User must exist
        IF NOT EXISTS (SELECT 1 FROM Users WHERE UserId = @UserId)
        BEGIN
            SET @Message = 'User not found';
            ROLLBACK; RETURN;
        END

        -- [DA2] Cannot deactivate admin
        DECLARE @RoleName NVARCHAR(50);
        SELECT @RoleName = r.RoleName FROM Users u INNER JOIN Roles r ON u.RoleId=r.RoleId WHERE u.UserId=@UserId;
        IF @RoleName = 'Admin'
        BEGIN
            SET @Message = 'Admin accounts cannot be deactivated';
            ROLLBACK; RETURN;
        END

        -- [DA3] Idempotency
        DECLARE @IsActive BIT;
        SELECT @IsActive = IsActive FROM Users WHERE UserId = @UserId;
        IF @IsActive = 0
        BEGIN
            SET @Message = 'Account is already inactive';
            ROLLBACK; RETURN;
        END

        -- Deactivate the account
        UPDATE Users SET IsActive = 0, UpdatedAt = GETUTCDATE() WHERE UserId = @UserId;

        -- [DA4] Revoke all active refresh tokens — immediate session termination
        UPDATE RefreshTokens SET IsRevoked = 1 WHERE UserId = @UserId AND IsRevoked = 0;

        DECLARE @CancelledStatusId INT;
        SELECT @CancelledStatusId = StatusId FROM AppointmentStatuses WHERE StatusName = 'Cancelled';

        -- [DA5] Doctor-specific cleanup
        IF @RoleName = 'Doctor'
        BEGIN
            DECLARE @DoctorId INT;
            SELECT @DoctorId = DoctorId FROM Doctors WHERE UserId = @UserId;

            UPDATE Doctors SET IsAvailable = 0 WHERE DoctorId = @DoctorId;

            UPDATE Appointments
            SET StatusId           = @CancelledStatusId,
                CancellationReason = 'Doctor account has been deactivated. Your appointment has been cancelled. Please rebook with another doctor.',
                UpdatedAt          = GETUTCDATE()
            WHERE DoctorId = @DoctorId
              AND AppointmentDate >= CAST(GETUTCDATE() AS DATE)
              AND StatusId IN (SELECT StatusId FROM AppointmentStatuses WHERE StatusName IN ('Pending','Confirmed'));

            SET @Message = 'Doctor account deactivated. Sessions revoked. Future appointments cancelled.';
        END

        -- [DA6] Patient-specific cleanup
        ELSE IF @RoleName = 'Patient'
        BEGIN
            DECLARE @PatientId INT;
            SELECT @PatientId = PatientId FROM Patients WHERE UserId = @UserId;

            UPDATE Appointments
            SET StatusId           = @CancelledStatusId,
                CancellationReason = 'Patient account has been deactivated.',
                UpdatedAt          = GETUTCDATE()
            WHERE PatientId = @PatientId
              AND AppointmentDate >= CAST(GETUTCDATE() AS DATE)
              AND StatusId IN (SELECT StatusId FROM AppointmentStatuses WHERE StatusName IN ('Pending','Confirmed'));

            SET @Message = 'Patient account deactivated. Sessions revoked. Future appointments cancelled.';
        END

        COMMIT;
    END TRY
    BEGIN CATCH
        IF @@TRANCOUNT > 0 ROLLBACK;
        SET @Message = ERROR_MESSAGE();
    END CATCH
END
GO

