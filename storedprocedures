-- ============================================================
-- PRESCRIPTION PROCEDURES
-- ============================================================

-- Edge cases covered:
--   [P1] Appointment must exist
--   [P2] Appointment must be Confirmed or Completed (not Pending/Cancelled/NoShow)
--   [P3] Doctor ownership: only the appointment's doctor can write it
--   [P4] Follow-up date must be in the future
--   [P5] Upsert: if prescription exists, update it (doctor can revise notes)
CREATE OR ALTER PROCEDURE sp_AddPrescription
    @AppointmentId     INT,
    @Diagnosis         NVARCHAR(500),
    @Medications       NVARCHAR(MAX),
    @Instructions      NVARCHAR(MAX),
    @FollowUpDate      DATE = NULL,
    @WrittenByDoctorId INT  = NULL,
    @PrescriptionId    INT OUTPUT,
    @Message           NVARCHAR(200) OUTPUT
AS
BEGIN
    SET NOCOUNT ON;
    BEGIN TRY
        BEGIN TRANSACTION;

        DECLARE @StatusName NVARCHAR(50), @AppointmentDoctorId INT;

        SELECT @StatusName          = ast.StatusName,
               @AppointmentDoctorId = a.DoctorId
        FROM Appointments a
        INNER JOIN AppointmentStatuses ast ON a.StatusId = ast.StatusId
        WHERE a.AppointmentId = @AppointmentId;

        -- [P1] Appointment must exist
        IF @StatusName IS NULL
        BEGIN
            SET @PrescriptionId = -1;  SET @Message = 'Appointment not found';
            ROLLBACK; RETURN;
        END

        -- [P3] Ownership check
        IF @WrittenByDoctorId IS NOT NULL AND @AppointmentDoctorId != @WrittenByDoctorId
        BEGIN
            SET @PrescriptionId = -1;
            SET @Message = 'You can only write prescriptions for your own appointments';
            ROLLBACK; RETURN;
        END

        -- [P2] Status must be Confirmed or Completed
        IF @StatusName NOT IN ('Confirmed','Completed')
        BEGIN
            SET @PrescriptionId = -1;
            SET @Message = 'Prescriptions can only be added to Confirmed or Completed appointments (current: ' + @StatusName + ')';
            ROLLBACK; RETURN;
        END

        -- [P4] Follow-up date must be future
        IF @FollowUpDate IS NOT NULL AND @FollowUpDate <= CAST(GETUTCDATE() AS DATE)
        BEGIN
            SET @PrescriptionId = -1;  SET @Message = 'Follow-up date must be a future date';
            ROLLBACK; RETURN;
        END

        -- [P5] Upsert
        IF EXISTS (SELECT 1 FROM Prescriptions WHERE AppointmentId = @AppointmentId)
        BEGIN
            UPDATE Prescriptions
            SET Diagnosis = @Diagnosis, Medications = @Medications,
                Instructions = @Instructions, FollowUpDate = @FollowUpDate, UpdatedAt = GETUTCDATE()
            WHERE AppointmentId = @AppointmentId;

            SELECT @PrescriptionId = PrescriptionId FROM Prescriptions WHERE AppointmentId = @AppointmentId;
            SET @Message = 'Prescription updated successfully';
        END
        ELSE
        BEGIN
            INSERT INTO Prescriptions (AppointmentId, Diagnosis, Medications, Instructions, FollowUpDate)
            VALUES (@AppointmentId, @Diagnosis, @Medications, @Instructions, @FollowUpDate);
            SET @PrescriptionId = SCOPE_IDENTITY();
            SET @Message = 'Prescription added successfully';
        END

        COMMIT;
    END TRY
    BEGIN CATCH
        IF @@TRANCOUNT > 0 ROLLBACK;
        SET @PrescriptionId = -1;  SET @Message = ERROR_MESSAGE();
    END CATCH
END
GO

