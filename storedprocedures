CREATE OR ALTER PROCEDURE sp_CreateDoctor
    @FullName           NVARCHAR(150),
    @Email              NVARCHAR(200),
    @PasswordHash       NVARCHAR(500),
    @Phone              NVARCHAR(15)   = NULL,
    @SpecializationId   INT,
    @LicenseNumber      NVARCHAR(100),
    @YearsOfExperience  INT            = 0,
    @ConsultationFee    DECIMAL(10,2)  = 0,
    @UserId             INT OUTPUT,
    @DoctorId           INT OUTPUT,
    @Message            NVARCHAR(200) OUTPUT
AS
BEGIN
    SET NOCOUNT ON;
    BEGIN TRY
        BEGIN TRANSACTION;
 
        IF EXISTS (SELECT 1 FROM Users WHERE Email = @Email)
        BEGIN
            SET @UserId = -1; SET @DoctorId = -1;
            SET @Message = 'An account with this email already exists';
            ROLLBACK; RETURN;
        END
 
        IF EXISTS (SELECT 1 FROM Doctors WHERE LicenseNumber = @LicenseNumber)
        BEGIN
            SET @UserId = -1; SET @DoctorId = -1;
            SET @Message = 'This license number is already registered';
            ROLLBACK; RETURN;
        END
 
        IF NOT EXISTS (SELECT 1 FROM Specializations WHERE SpecializationId = @SpecializationId)
        BEGIN
            SET @UserId = -1; SET @DoctorId = -1;
            SET @Message = 'Specialization not found';
            ROLLBACK; RETURN;
        END
 
        IF @ConsultationFee < 0
        BEGIN
            SET @UserId = -1; SET @DoctorId = -1;
            SET @Message = 'Consultation fee cannot be negative';
            ROLLBACK; RETURN;
        END
 
        DECLARE @DoctorRoleId INT;
        SELECT @DoctorRoleId = RoleId FROM Roles WHERE RoleName = 'Doctor';
 
        INSERT INTO Users (FullName, Email, PasswordHash, Phone, RoleId)
        VALUES (@FullName, @Email, @PasswordHash, @Phone, @DoctorRoleId);
        SET @UserId = SCOPE_IDENTITY();
 
        INSERT INTO Doctors (UserId, SpecializationId, LicenseNumber, YearsOfExperience, ConsultationFee)
        VALUES (@UserId, @SpecializationId, @LicenseNumber, @YearsOfExperience, @ConsultationFee);
        SET @DoctorId = SCOPE_IDENTITY();
 
        SET @Message = 'Doctor account created successfully';
        COMMIT;
    END TRY
    BEGIN CATCH
        IF @@TRANCOUNT > 0 ROLLBACK;
        SET @UserId = -1; SET @DoctorId = -1;
        SET @Message = ERROR_MESSAGE();
    END CATCH
END
GO
