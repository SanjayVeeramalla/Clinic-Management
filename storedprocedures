-- Edge cases covered:
--   [A1] Admin role cannot be self-registered
--   [A2] Duplicate email (case-insensitive)
--   [A3] Invalid role name
CREATE OR ALTER PROCEDURE sp_RegisterUser
    @FullName     NVARCHAR(150),
    @Email        NVARCHAR(200),
    @PasswordHash NVARCHAR(500),
    @Phone        NVARCHAR(15),
    @RoleName     NVARCHAR(50),
    @UserId       INT OUTPUT,
    @Message      NVARCHAR(200) OUTPUT
AS
BEGIN
    SET NOCOUNT ON;
    BEGIN TRY
        BEGIN TRANSACTION;

        -- [A1] Admin accounts can only be seeded, not self-registered
        IF @RoleName = 'Admin'
        BEGIN
            SET @UserId = -1;  SET @Message = 'Admin accounts cannot be self-registered';
            ROLLBACK; RETURN;
        END

        -- [A2] Duplicate email check
        IF EXISTS (SELECT 1 FROM Users WHERE Email = @Email)
        BEGIN
            SET @UserId = -1;  SET @Message = 'An account with this email already exists';
            ROLLBACK; RETURN;
        END

        -- [A3] Role must exist
        DECLARE @RoleId INT;
        SELECT @RoleId = RoleId FROM Roles WHERE RoleName = @RoleName;
        IF @RoleId IS NULL
        BEGIN
            SET @UserId = -1;  SET @Message = 'Invalid role specified';
            ROLLBACK; RETURN;
        END

        INSERT INTO Users (FullName, Email, PasswordHash, Phone, RoleId)
        VALUES (@FullName, @Email, @PasswordHash, @Phone, @RoleId);

        SET @UserId = SCOPE_IDENTITY();
        SET @Message = 'User registered successfully';
        COMMIT;
    END TRY
    BEGIN CATCH
        IF @@TRANCOUNT > 0 ROLLBACK;
        SET @UserId = -1;  SET @Message = ERROR_MESSAGE();
    END CATCH
END
GO

-- Edge case: Only returns rows for ACTIVE users.
-- Deactivated accounts get no rows — service treats as "invalid credentials"
-- This avoids telling the caller that the account exists but is disabled (security).
CREATE OR ALTER PROCEDURE sp_GetUserByEmail
    @Email NVARCHAR(200)
AS
BEGIN
    SET NOCOUNT ON;
    SELECT u.UserId, u.FullName, u.Email, u.PasswordHash, u.Phone,
           u.IsActive, u.CreatedAt, r.RoleName
    FROM Users u
    INNER JOIN Roles r ON u.RoleId = r.RoleId
    WHERE u.Email = @Email AND u.IsActive = 1;
END
GO

