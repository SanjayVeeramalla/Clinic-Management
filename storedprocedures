-- *** KEY REAL-WORLD EDGE CASE ***
-- Edge cases covered:
--   [U1] Doctor not found
--   [U2] Fee cannot be negative
--   [U3] Doctor sets IsAvailable = 0 (goes on leave/unavailable):
--         → Auto-cancel ALL future Pending + Confirmed appointments
--         → Clear cancellation reason explains why to patient
--   Note: Schedule changes do NOT retroactively cancel booked appointments.
--         Existing bookings are honoured regardless of schedule changes.
CREATE OR ALTER PROCEDURE sp_UpdateDoctor
    @DoctorId          INT,
    @SpecializationId  INT,
    @YearsOfExperience INT,
    @ConsultationFee   DECIMAL(10,2),
    @IsAvailable       BIT,
    @Message           NVARCHAR(200) OUTPUT
AS
BEGIN
    SET NOCOUNT ON;
    BEGIN TRY
        BEGIN TRANSACTION;

        -- [U1] Doctor must exist
        IF NOT EXISTS (SELECT 1 FROM Doctors WHERE DoctorId = @DoctorId)
        BEGIN
            SET @Message = 'Doctor not found';
            ROLLBACK; RETURN;
        END

        -- [U2] Fee sanity
        IF @ConsultationFee < 0
        BEGIN
            SET @Message = 'Consultation fee cannot be negative';
            ROLLBACK; RETURN;
        END

        -- Capture previous availability before update
        DECLARE @WasAvailable BIT;
        SELECT @WasAvailable = IsAvailable FROM Doctors WHERE DoctorId = @DoctorId;

        UPDATE Doctors
        SET SpecializationId  = @SpecializationId,
            YearsOfExperience = @YearsOfExperience,
            ConsultationFee   = @ConsultationFee,
            IsAvailable       = @IsAvailable
        WHERE DoctorId = @DoctorId;

        -- [U3] Doctor just went unavailable — cancel all future booked appointments
        IF @WasAvailable = 1 AND @IsAvailable = 0
        BEGIN
            DECLARE @CancelledStatusId INT;
            SELECT @CancelledStatusId = StatusId FROM AppointmentStatuses WHERE StatusName = 'Cancelled';

            UPDATE Appointments
            SET StatusId           = @CancelledStatusId,
                CancellationReason = 'Doctor is temporarily unavailable. Your appointment has been cancelled. Please rebook with another doctor or wait for the doctor to resume.',
                UpdatedAt          = GETUTCDATE()
            WHERE DoctorId = @DoctorId
              AND AppointmentDate >= CAST(GETUTCDATE() AS DATE)
              AND StatusId IN (SELECT StatusId FROM AppointmentStatuses WHERE StatusName IN ('Pending','Confirmed'));

            SET @Message = 'Doctor marked unavailable. All future pending/confirmed appointments have been cancelled.';
        END
        ELSE
        BEGIN
            SET @Message = 'Doctor updated successfully';
        END

        COMMIT;
    END TRY
    BEGIN CATCH
        IF @@TRANCOUNT > 0 ROLLBACK;
        SET @Message = ERROR_MESSAGE();
    END CATCH
END
GO

CREATE OR ALTER PROCEDURE sp_GetDoctorAppointments
    @DoctorId INT,
    @FromDate DATE = NULL,
    @ToDate   DATE = NULL,
    @StatusId INT  = NULL
AS
BEGIN
    SET NOCOUNT ON;
    SELECT a.AppointmentId, a.AppointmentDate, a.AppointmentTime,
           p.PatientId, u.FullName AS PatientName, u.Phone AS PatientPhone,
           ast.StatusName AS Status, a.ReasonForVisit, a.Notes, a.CancellationReason,
           pr.Diagnosis, pr.Medications
    FROM Appointments a
    INNER JOIN Patients p              ON a.PatientId   = p.PatientId
    INNER JOIN Users u                 ON p.UserId      = u.UserId
    INNER JOIN AppointmentStatuses ast ON a.StatusId    = ast.StatusId
    LEFT  JOIN Prescriptions pr         ON a.AppointmentId = pr.AppointmentId
    WHERE a.DoctorId = @DoctorId
      AND (@FromDate IS NULL OR a.AppointmentDate >= @FromDate)
      AND (@ToDate   IS NULL OR a.AppointmentDate <= @ToDate)
      AND (@StatusId IS NULL OR a.StatusId         = @StatusId)
    ORDER BY a.AppointmentDate DESC, a.AppointmentTime DESC;
END
GO

-- Edge cases covered:
--   [S1] Past date → return empty (no slots for past)
--   [S2] Doctor not active or not available → return empty
--   [S3] No schedule for this day of week → empty schedule result set
--   Returns two result sets: (1) schedule window, (2) booked times
--   Service layer computes free slots from these two.
CREATE OR ALTER PROCEDURE sp_GetDoctorAvailableSlots
    @DoctorId INT,
    @Date     DATE
AS
BEGIN
    SET NOCOUNT ON;

    -- [S1] Past date: return nothing
    IF @Date < CAST(GETUTCDATE() AS DATE)
    BEGIN
        SELECT NULL AS StartTime, NULL AS EndTime, NULL AS SlotDurationMinutes WHERE 1 = 0;
        RETURN;
    END

    -- [S2] Doctor must be available and active
    IF NOT EXISTS (
        SELECT 1 FROM Doctors d
        INNER JOIN Users u ON d.UserId = u.UserId
        WHERE d.DoctorId = @DoctorId AND d.IsAvailable = 1 AND u.IsActive = 1
    )
    BEGIN
        SELECT NULL AS StartTime, NULL AS EndTime, NULL AS SlotDurationMinutes WHERE 1 = 0;
        RETURN;
    END

    -- DayOfWeek: SQL Server DATEPART gives 1=Sunday...7=Saturday, convert to 0-based
    DECLARE @DayOfWeek INT = DATEPART(WEEKDAY, @Date) - 1;

    -- [S3] Working schedule for the day (may return 0 rows if doctor doesn't work this day)
    SELECT ds.StartTime, ds.EndTime, ds.SlotDurationMinutes
    FROM DoctorSchedules ds
    WHERE ds.DoctorId = @DoctorId AND ds.DayOfWeek = @DayOfWeek AND ds.IsActive = 1;

    -- Already-booked times (excluding cancelled and no-show)
    SELECT a.AppointmentTime
    FROM Appointments a
    WHERE a.DoctorId        = @DoctorId
      AND a.AppointmentDate = @Date
      AND a.StatusId NOT IN (SELECT StatusId FROM AppointmentStatuses WHERE StatusName IN ('Cancelled','NoShow'));
END
GO

-- Edge cases covered:
--   [SC1] DayOfWeek must be 0–6
--   [SC2] StartTime must be before EndTime
--   [SC3] SlotDuration must be positive
--   [SC4] Working window must fit at least one slot
--   [SC5] Doctor must exist
--   Note: Existing booked appointments are NOT cancelled when schedule changes.
--         Schedule changes only affect future bookings (prospective only).
CREATE OR ALTER PROCEDURE sp_SetDoctorSchedule
    @DoctorId            INT,
    @DayOfWeek           INT,
    @StartTime           TIME,
    @EndTime             TIME,
    @SlotDurationMinutes INT,
    @Message             NVARCHAR(200) OUTPUT
AS
BEGIN
    SET NOCOUNT ON;
    BEGIN TRY
        -- [SC1] Day of week validation
        IF @DayOfWeek < 0 OR @DayOfWeek > 6
        BEGIN
            SET @Message = 'DayOfWeek must be 0 (Sunday) through 6 (Saturday)';
            RETURN;
        END

        -- [SC2] Start before end
        IF @StartTime >= @EndTime
        BEGIN
            SET @Message = 'Start time must be before end time';
            RETURN;
        END

        -- [SC3] Positive duration
        IF @SlotDurationMinutes <= 0
        BEGIN
            SET @Message = 'Slot duration must be a positive number of minutes';
            RETURN;
        END

        -- [SC4] At least one slot must fit
        IF DATEDIFF(MINUTE, @StartTime, @EndTime) < @SlotDurationMinutes
        BEGIN
            SET @Message = 'Working window is shorter than one slot duration';
            RETURN;
        END

        -- [SC5] Doctor must exist
        IF NOT EXISTS (SELECT 1 FROM Doctors WHERE DoctorId = @DoctorId)
        BEGIN
            SET @Message = 'Doctor not found';
            RETURN;
        END

        IF EXISTS (SELECT 1 FROM DoctorSchedules WHERE DoctorId = @DoctorId AND DayOfWeek = @DayOfWeek)
            UPDATE DoctorSchedules
            SET StartTime = @StartTime, EndTime = @EndTime, SlotDurationMinutes = @SlotDurationMinutes, IsActive = 1
            WHERE DoctorId = @DoctorId AND DayOfWeek = @DayOfWeek;
        ELSE
            INSERT INTO DoctorSchedules (DoctorId, DayOfWeek, StartTime, EndTime, SlotDurationMinutes)
            VALUES (@DoctorId, @DayOfWeek, @StartTime, @EndTime, @SlotDurationMinutes);

        SET @Message = 'Schedule saved successfully. Existing booked appointments are unaffected.';
    END TRY
    BEGIN CATCH
        SET @Message = ERROR_MESSAGE();
    END CATCH
END
GO

