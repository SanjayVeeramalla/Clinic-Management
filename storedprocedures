CREATE OR ALTER PROCEDURE sp_CreatePatient
    @UserId           INT,
    @DateOfBirth      DATE        = NULL,
    @Gender           NVARCHAR(10) = NULL,
    @BloodGroup       NVARCHAR(5)  = NULL,
    @Address          NVARCHAR(300)= NULL,
    @EmergencyContact NVARCHAR(15) = NULL,
    @PatientId        INT OUTPUT,
    @Message          NVARCHAR(200) OUTPUT
AS
BEGIN
    SET NOCOUNT ON;
    BEGIN TRY
        BEGIN TRANSACTION;

        IF EXISTS (SELECT 1 FROM Patients WHERE UserId = @UserId)
        BEGIN
            SET @PatientId = -1;  SET @Message = 'Patient profile already exists for this user';
            ROLLBACK; RETURN;
        END

        IF @DateOfBirth IS NOT NULL
        BEGIN
            IF @DateOfBirth >= CAST(GETUTCDATE() AS DATE)
            BEGIN
                SET @PatientId = -1;  SET @Message = 'Date of birth must be in the past';
                ROLLBACK; RETURN;
            END
        END

        INSERT INTO Patients (UserId, DateOfBirth, Gender, BloodGroup, Address, EmergencyContact)
        VALUES (@UserId, @DateOfBirth, @Gender, @BloodGroup, @Address, @EmergencyContact);

        SET @PatientId = SCOPE_IDENTITY();
        SET @Message   = 'Patient profile created successfully';
        COMMIT;
    END TRY
    BEGIN CATCH
        IF @@TRANCOUNT > 0 ROLLBACK;
        SET @PatientId = -1;  SET @Message = ERROR_MESSAGE();
    END CATCH
END
GO
